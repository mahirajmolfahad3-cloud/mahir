```gitignore
# Dependencies
node_modules/

# Next.js
.next/
out/

# Production
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# TypeScript
*.tsbuildinfo

# Coverage
coverage/

# Vercel
.vercel/

# Turbopack
.turbo/

# IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Cache
.cache/
.eslintcache

# Temporary files
*.tmp
*.temp
```
